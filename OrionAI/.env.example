# ─────────────────────────────────────────────────────────
# OrionAI — Environment Variables
# ─────────────────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN YOUR REAL VALUES
# NEVER commit .env to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────

# ── JWT Auth ──────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=orionai-secret-key-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_TTL=60

# ── Database ──────────────────────────────────────────────
# SQLite (dev): sqlite:///./orionai.db
# PostgreSQL (prod): postgresql+asyncpg://user:password@host:5432/orionai
DATABASE_URL=sqlite:///./orionai.db

# ── External APIs (optional — used in production only) ────
# OpenWeatherMap API key for real weather data
OWM_API_KEY=

# OpenRouteService API key for real road routing
ORS_API_KEY=

# ── Firebase (optional — server-side Admin SDK) ───────────
# Only needed if you use Firebase Admin SDK server-side
# FIREBASE_ADMIN_CREDENTIALS_JSON=./firebase-service-account.json
