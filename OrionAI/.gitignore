# ─────────────────────────────────────────────────────────────
# OrionAI — .gitignore
# ─────────────────────────────────────────────────────────────

# ── SECRETS & CREDENTIALS (NEVER COMMIT) ──────────────────────
.env
firebase-config.js
firebase-service-account.json
*-credentials.json
*.pem
*.key
*.p12
*.pfx
gcp-credentials*.json

# ── PYTHON ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
dist/
build/
*.egg

# ── VIRTUAL ENVIRONMENTS ──────────────────────────────────────
.venv/
venv/
env/
ENV/
.tmpvenv/
.tmpdeps/

# ── DATABASE (dev data) ───────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE / EDITOR ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS FILES ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── LOGS ──────────────────────────────────────────────────────
*.log
logs/

# ── NODE (if added later) ─────────────────────────────────────
node_modules/
.npm/

# ── BUILD OUTPUT ──────────────────────────────────────────────
dist/
.output/
.cache/
